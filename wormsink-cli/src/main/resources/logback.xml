<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>wormsink.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence any console appender, log all messages to file -->
    <root level="INFO">
        <appender-ref ref="FILE" />
    </root>
</configuration>
